# ============================================================
# FluencyLens — Environment Variables
# Copy to backend/.env and frontend/.env.local
# ============================================================

# ----------------------------
# Backend (backend/.env)
# ----------------------------

# Pipeline mode: RULES_ONLY (always works) | HYBRID_ML (requires wav2vec2 models)
ANALYSIS_MODE=RULES_ONLY

# faster-whisper model: tiny.en | base.en | small.en | medium.en
WHISPER_MODEL=base.en

# SQLite database (relative to backend/ directory)
DATABASE_URL=sqlite:///./fluencylens.db

# ML model paths (only needed for HYBRID_ML mode)
WAV2VEC_CLASSIFIER_PATH=ml_cache/classifier.pkl
WAV2VEC_EMBEDDINGS_PATH=ml_cache/sep28k_embeddings.npy

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# ----------------------------
# Frontend (frontend/.env.local)
# ----------------------------

# Backend base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000
